(*Constants*)

R = 8.314;      (*J/mol/K*)
Ea = 95000;     (*J/mol*)
k0 = 1*10^7;    (*pre-exponential factor*)

(*Kinetics:Arrhenius rate,first-order plug flow*)

k[T_] := k0 Exp[-Ea/(R T)]
conversionKinetic[T_, tau_] := 1 - Exp[-k[T] tau]

(*Thermodynamic equilibrium limit*)

Keq[T_] := Exp[6000/T - 6]
equilibriumLimit[T_] := Keq[T]/(1 + Keq[T])

(*Effective conversion: whichever limit binds*)

conversionTotal[T_, tau_] := 
 Min[conversionKinetic[T, tau], equilibriumLimit[T]]

(*H2SO4 yield: stoichiometric conversion from SO2*)

h2so4Yield[T_, tau_] := 1.53*conversionTotal[T, tau]

(*1. Kinetic conversion at tau=1s*)

Plot[conversionKinetic[T, 1], {T, 400, 900}, 
 AxesLabel -> {"Temperature (K)", "SO2 conversion"}, 
 PlotRange -> {0, 1}, PlotLabel -> "Kinetic conversion (tau = 1s)"]

(*2. Effect of residence time on kinetic conversion*)

Plot[{conversionKinetic[T, 0.1], conversionKinetic[T, 1], 
  conversionKinetic[T, 10]}, {T, 400, 900}, 
 PlotLegends -> {"tau = 0.1 s", "tau = 1 s", "tau = 10 s"}, 
 AxesLabel -> {"Temperature (K)", "SO2 conversion"}, 
 PlotRange -> {0, 1}]

(*3. Equilibrium limit*)

Plot[equilibriumLimit[T], {T, 400, 900}, 
 AxesLabel -> {"Temperature (K)", "Equilibrium conversion limit"}, 
 PlotRange -> {0, 1}]

(*4. Kinetic vs equilibrium vs effective conversion*)

Plot[{conversionKinetic[T, 1], equilibriumLimit[T], 
  conversionTotal[T, 1]}, {T, 400, 900}, 
 PlotLegends -> {"Kinetic", "Equilibrium", "Effective"}, 
 AxesLabel -> {"Temperature (K)", "SO2 conversion"}, 
 PlotRange -> {0, 1}]

(*5. H2SO4 yield*)

Plot[h2so4Yield[T, 1], {T, 400, 900}, 
 AxesLabel -> {"Temperature (K)", "g H2SO4 per g SO2"}, 
 PlotRange -> {0, 1.6}]

(*6. Optimal temperature*)

NMaximize[{conversionTotal[T, 1], 400 < T < 900}, T]
